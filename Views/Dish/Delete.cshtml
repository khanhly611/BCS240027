@model MID_BCS240027.Models.Dish_BCS240027

<h2>Xóa món ăn</h2>

<div class="alert alert-danger">
    Bạn có chắc muốn xóa món ăn này?
</div>

<table class="table">

    <tr>
        <th>Tên món ăn</th>
        <td>@Model.Name</td>
    </tr>

    <tr>
        <th>Giá</th>
        <td>@Model.Price</td>
    </tr>

</table>

<form asp-action="Delete">

    <input asp-for="Id"
           type="hidden" />

    <button class="btn btn-danger">
        Xóa
    </button>

    <a asp-action="Index"
       class="btn btn-secondary">
        Hủy
    </a>

</form>